# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit your actual API keys.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions
CONTACT_TO_EMAIL=you@example.com

# Sender address. Until you verify your own domain in Resend, you can only
# send from "onboarding@resend.dev" (Resend's shared sender).
# Once you verify your domain at Resend → Domains, change this to:
#   "Your Brand <contact@your-domain.com>"
CONTACT_FROM_EMAIL=Your Brand Contact <onboarding@resend.dev>
